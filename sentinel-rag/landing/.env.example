# Sentinel-RAG landing — environment variables
# Copy to .env.local and adjust for your deployment.

# Public FastAPI base URL (browser + server-side proxy)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-only: API URL for Next.js route handlers (defaults to NEXT_PUBLIC_API_URL)
# SENTINEL_API_URL=http://localhost:8000

# Optional API key if SENTINEL_API_KEY is set on the FastAPI server
# SENTINEL_API_KEY=

# Optional: override external links
# NEXT_PUBLIC_STREAMLIT_URL=http://localhost:8501
# NEXT_PUBLIC_DOCS_URL=https://github.com/you/sentinel-rag/tree/main/sentinel-rag/docs
